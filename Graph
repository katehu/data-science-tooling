# Convert wildfire data to sf object
pts <- st_as_sf(
  dat_wf,
  coords = c("LONGITUDE", "LATITUDE"),
  crs = 4326,
  remove = FALSE
)

# Load U.S. state boundaries
states_sf <- tigris::states(cb = TRUE, resolution = "20m") %>%
  st_transform(4326) %>%
  select(STATE_NAME = NAME, STATE_ABBR = STUSPS, geometry)

# Get top N states by total FRP
top_states <- dat_wf %>%
  filter(!is.na(STATE_NAME), !is.na(FRP)) %>%
  group_by(STATE_NAME) %>%
  summarise(total_frp = sum(FRP, na.rm = TRUE), .groups = "drop") %>%
  arrange(desc(total_frp)) %>%
  slice_head(n = topN) %>%
  pull(STATE_NAME)

# Function to draw one state map
make_state_map <- function(state_name, color_var = c("TEMP_C", "Abs_Temp")) {
  color_var <- match.arg(color_var)

  dat_state <- pts[pts$STATE_NAME == state_name, ]
  st_outline <- states_sf[states_sf$STATE_NAME == state_name, ]

  if (nrow(dat_state) == 0) {
    stop("No wildfire points found for state: ", state_name)
  }

  if (nrow(st_outline) == 0) {
    stop("No boundary found for state: ", state_name)
  }

  bbox <- st_bbox(st_outline)

  ttl <- if (color_var == "TEMP_C") {
    paste0(state_name, " — Color: TEMP_C")
  } else {
    paste0(state_name, " — Color: Abs_Temp")
  }

  ggplot() +
    geom_sf(
      data = st_outline,
      fill = "gray95",
      color = "black",
      linewidth = 0.5
    ) +
    geom_sf(
      data = dat_state,
      aes(color = .data[[color_var]], size = FRP),
      alpha = 0.60
    ) +
    scale_color_viridis_c(
      name = color_var,
      na.value = "grey85"
    ) +
    scale_size_continuous(
      name = "FRP",
      range = c(0.6, 4)
    ) +
    coord_sf(
      xlim = c(bbox["xmin"], bbox["xmax"]),
      ylim = c(bbox["ymin"], bbox["ymax"]),
      expand = FALSE
    ) +
    labs(
      title = ttl,
      x = "Longitude",
      y = "Latitude"
    ) +
    theme_minimal(base_size = 12) +
    theme(
      plot.title = element_text(face = "bold", size = 13),
      legend.position = "right"
    )
}

# Save one page per state, two maps per page
pdf(outpdf_state_maps, width = 14, height = 6)

for (st in top_states) {
  p1 <- make_state_map(st, "TEMP_C")
  p2 <- make_state_map(st, "Abs_Temp")

  combined <- (p1 | p2) +
    plot_annotation(
      title = paste0("Wildfire detections — ", st, " (FRP size; 2022)")
    )

  print(combined)
}

