outpdf_state_maps <- "C:/Users/16144/Desktop/top_states_TEMPc_vs_AbsTemp_2022.pdf"
topN <- 8

# Check required columns
need_cols <- c("LONGITUDE", "LATITUDE", "FRP", "TEMP_C", "Abs_Temp", "STATE_NAME")
