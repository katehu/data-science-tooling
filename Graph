# 6. Top 10 states by total FRP

if (!("STATE_NAME" %in% names(dat_clean))) {
  pts_sf <- st_as_sf(dat_clean, coords = c("LONGITUDE", "LATITUDE"), crs = 4326, remove = FALSE)
  states_sf_for_join <- tigris::states(cb = TRUE, resolution = "20m") %>%
    st_transform(4326) %>%
    select(STATE_NAME = NAME, geometry)

  pts_joined <- st_join(pts_sf, states_sf_for_join, left = TRUE)
  dat_clean$STATE_NAME <- pts_joined$STATE_NAME
  dat_wf$STATE_NAME <- pts_joined$STATE_NAME[match(1:nrow(dat_wf), which(dat_clean$Incid_Type == dat_wf$Incid_Type))]
}

state_top10 <- dat_wf %>%
  filter(!is.na(STATE_NAME), !is.na(FRP), FRP > 0) %>%
  group_by(STATE_NAME) %>%
  summarise(total_frp = sum(FRP, na.rm = TRUE), .groups = "drop") %>%
  arrange(desc(total_frp)) %>%
  slice(1:10)

p_top10 <- ggplot(state_top10,
                  aes(x = reorder(STATE_NAME, total_frp), y = total_frp)) +
  geom_col(fill = "#2C7BB6") +
  coord_flip() +
  labs(
