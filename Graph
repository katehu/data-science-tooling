# 9. state season FRP group plots

outpdf_state_season <- "C:/Users/16144/Desktop/All_States_TempAnom_FRP_Seasons_2022.pdf"

get_season <- function(m) {
  if (m %in% 3:5) return("Spring")
  if (m %in% 6:7) return("EarlySummer")
  if (m %in% 8:9) return("LateSummer")
  return(NA_character_)
}

dat_season <- copy(dat_wf)

if (!("STATE_NAME" %in% names(dat_season))) {
  dat_season$STATE_NAME <- pts2$STATE_NAME
}

dat_season[, MONTH2 := month(DATE)]
dat_season[, Season := vapply(MONTH2, get_season, character(1))]
dat_season <- dat_season[!is.na(Season) & !is.na(TEMP_ANOM) & !is.na(FRP) & !is.na(STATE_NAME)]

frp_thresholds <- c(0, 200, 1000)

make_daily_df <- function(dt, thr) {
  dt %>%
    group_by(STATE_NAME, Season, DATE) %>%
    summarise(
      Temp = mean(TEMP_ANOM, na.rm = TRUE),
      Count = sum(FRP > thr, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    mutate(FRP_Group = paste0("FRP > ", thr))
}

daily_all_states <- bind_rows(lapply(frp_thresholds, \(thr) make_daily_df(dat_season, thr))) %>%
  mutate(FRP_Group = factor(FRP_Group, levels = paste0("FRP > ", frp_thresholds)))

plot_state_season <- function(state_name, season_name) {
  dfp <- daily_all_states %>%
    filter(STATE_NAME == state_name, Season == season_name)

  if (nrow(dfp) == 0) return(NULL)

  ggplot(dfp, aes(x = Temp, y = Count)) +
    geom_point(alpha = 0.55, size = 2) +
    geom_smooth(method = "lm", se = FALSE) +
    facet_wrap(~FRP_Group, nrow = 1, scales = "free_y") +
    labs(
      title = paste0(state_name, " — ", season_name, " (2022)"),
      x = "Daily mean Temp anomaly (°C)",
      y = "Daily wildfire detection count"
    ) +
    theme_minimal(base_size = 14) +
    theme(
      plot.title = element_text(face = "bold"),
      panel.spacing.x = grid::unit(1.4, "lines")
    )
}

states_all <- sort(unique(daily_all_states$STATE_NAME))
seasons <- c("Spring", "EarlySummer", "LateSummer")

pdf(outpdf_state_season, width = 18, height = 6)

for (st in states_all) {
  for (ss in seasons) {
    p <- plot_state_season(st, ss)
    if (!is.null(p)) print(p)
  }
}

dev.off()

