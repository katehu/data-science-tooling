# 1. Read data
infile <- "C:/Users/16144/Desktop/fire_2022_final.csv"
dat <- fread(infile)

if ("DATE" %in% names(dat)) {
  dat[, DATE := as.Date(DATE)]
}

if (!("TEMP_C" %in% names(dat))) {
  if ("TEMP" %in% names(dat)) {
    dat[, TEMP_C := ifelse(is.na(TEMP), NA_real_, TEMP - 273.15)]
  } else {
    stop("Missing TEMP and TEMP_C columns.")
  }
}

if (!("TEMP_ANOM" %in% names(dat))) {
  if ("tempanom" %in% names(dat)) {
    dat[, TEMP_ANOM := tempanom]
  } else if ("anomalyC" %in% names(dat)) {
    dat[, TEMP_ANOM := anomalyC]
  } else if ("TEMP_ABS" %in% names(dat)) {
    dat[, TEMP_ANOM := TEMP_ABS]
  } else if ("Abs_Temp" %in% names(dat)) {
    dat[, TEMP_ANOM := Abs_Temp]
  } else if (all(c("TEMP_C", "CLIM_TEMP") %in% names(dat))) {
    dat[, TEMP_ANOM := TEMP_C - CLIM_TEMP]
  } else {
    dat[, TEMP_ANOM := NA_real_]
  }
}

if (!("MONTH" %in% names(dat))) {
  if ("DATE" %in% names(dat)) {
    dat[, MONTH := month(DATE)]
  }
}

dat_clean <- dat[
  !is.na(LONGITUDE) & !is.na(LATITUDE) &
  LONGITUDE >= -125 & LONGITUDE <= -67 &
  LATITUDE  >=  25  & LATITUDE  <=  50
]

if ("Incid_Type" %in% names(dat_clean)) {
  dat_wf <- dat_clean[Incid_Type == "Wildfire"]
} else if ("TYPE" %in% names(dat_clean)) {
  dat_wf <- dat_clean[TYPE == 0]
} else {
  dat_wf <- copy(dat_clean)
}

us_states <- map_data("state")


