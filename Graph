  theme_minimal()

print(p_top10)


# 7. different FRP thresholds

make_daily <- function(df){
  df %>%
    group_by(DATE) %>%
    summarise(
      fire_count = n(),
      mean_tempC = mean(TEMP_C, na.rm = TRUE),
      .groups = "drop"
    )
}

daily_all   <- make_daily(dat_wf %>% filter(FRP > 0))    %>% mutate(group = "FRP > 0")
daily_200   <- make_daily(dat_wf %>% filter(FRP > 200))  %>% mutate(group = "FRP > 200")
daily_1000  <- make_daily(dat_wf %>% filter(FRP > 1000)) %>% mutate(group = "FRP > 1000")

daily_stack <- bind_rows(daily_all, daily_200, daily_1000)

p_thr_scatter <- ggplot(daily_stack, aes(x = mean_tempC, y = fire_count)) +
  geom_point(alpha = 0.35) +
  geom_smooth(method = "lm", se = FALSE) +
  facet_wrap(~group, scales = "free_y") +
  labs(
    title = "Temperature vs Fire Frequency under Different FRP Thresholds",
    x = "Daily mean Temp (°C)",
    y = "Daily wildfire detection count"
  ) +
  theme_minimal(base_size = 13)

print(p_thr_scatter)

bin_summary <- function(df, label){
  df %>%
    group_by(DATE) %>%
    summarise(
      fire_count = n(),
      mean_tempC = mean(TEMP_C, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    mutate(temp_bin = cut(mean_tempC, breaks = seq(-10, 45, 5), include.lowest = TRUE)) %>%
    group_by(temp_bin) %>%
    summarise(mean_fire = mean(fire_count), n_days = n(), .groups = "drop") %>%
    mutate(group = label)
}

b_all  <- bin_summary(dat_wf %>% filter(FRP > 0), "FRP > 0")
b_200  <- bin_summary(dat_wf %>% filter(FRP > 200), "FRP > 200")
b_1000 <- bin_summary(dat_wf %>% filter(FRP > 1000), "FRP > 1000")

b <- bind_rows(b_all, b_200, b_1000)

p_thr_bin <- ggplot(b, aes(x = temp_bin, y = mean_fire, group = group)) +
  geom_line() +
  geom_point() +
  facet_wrap(~group, scales = "free_y") +
  labs(
    title = "Binned Temp vs Mean Daily Fire Frequency by FRP Threshold",
    x = "Temperature bin (°C)",
    y = "Mean daily fire count"
  ) +
  theme_minimal(base_size = 13) +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

print(p_thr_bin)


